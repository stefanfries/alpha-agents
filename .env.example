# =============================================================================
# Alpha Agents — environment template
# Copy this file to .env and fill in your values.
# .env is gitignored; this file is safe to commit.
# =============================================================================

# --- Database (MongoDB Atlas) ------------------------------------------------
DB__MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DB__DB_NAME=alpha_agents

# --- Broker (Comdirect) ------------------------------------------------------
BROKER__CLIENT_ID=your-comdirect-client-id
BROKER__CLIENT_SECRET=your-comdirect-client-secret

# --- FinHub API --------------------------------------------------------------
FINHUB__BASE_URL=https://ca-fastapi.yellowwater-786ec0d0.germanywestcentral.azurecontainerapps.io
FINHUB__TIMEOUT_S=65

# --- Research ----------------------------------------------------------------
RESEARCH__LOOKBACK_DAYS=365

# --- Screening ---------------------------------------------------------------
SCREENING__TOP_N=20
SCREENING__MIN_MARKET_CAP_EUR=500000000

# --- Monitoring --------------------------------------------------------------
MONITORING__MIN_HOLDING_DAYS=5
MONITORING__RE_ENTRY_PREVENTION_DAYS=10
MONITORING__WARRANT_HEALTH__ENABLED=true
MONITORING__WARRANT_HEALTH__SPREAD_MAX_PCT=2.5
MONITORING__WARRANT_HEALTH__LEVERAGE_MIN=3.0
MONITORING__WARRANT_HEALTH__LEVERAGE_MAX=8.0
MONITORING__WARRANT_HEALTH__MIN_DAYS_TO_MATURITY=60
MONITORING__WARRANT_HEALTH__DELTA_MIN=0.3
MONITORING__WARRANT_HEALTH__DELTA_MAX=0.7
MONITORING__WARRANT_HEALTH__MIN_WARRANT_SCORE=0.5

# --- Portfolio ---------------------------------------------------------------
PORTFOLIO__CAPITAL_EUR=100000
PORTFOLIO__SIZING_METHOD=equal
PORTFOLIO__MAX_POSITION_WEIGHT=0.10
PORTFOLIO__MAX_POSITIONS=20

# --- Risk --------------------------------------------------------------------
RISK__MAX_POSITION_WEIGHT=0.10
RISK__MAX_SECTOR_WEIGHT=0.30
RISK__MAX_POSITIONS=30

# --- Execution ---------------------------------------------------------------
# SAFETY: keep DRY_RUN=true until you are ready to place real orders
EXECUTION__DRY_RUN=true
EXECUTION__MIN_TRADE_EUR=1000.0
EXECUTION__ORDER_TYPE=limit

# --- UI ----------------------------------------------------------------------
UI__DARK_MODE=false

# --- Logging -----------------------------------------------------------------
LOG__LEVEL=INFO
